# ═══════════════════════════════════════════════════════════════════
# RIPS Guard — Variables de Entorno Requeridas
# Copiar como .env.local para desarrollo local
# En producción: Vercel → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────────
# Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Dashboard → Settings → API → anon (public) — segura para el browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Dashboard → Settings → API → service_role — SECRETO, solo server-side
# Usada por el webhook de Stripe para actualizar suscripciones
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────────────
# Developers → API Keys → Secret key
STRIPE_SECRET_KEY=sk_live_...

# Developers → Webhooks → Signing secret (endpoint /api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# Products → Plan Starter → Price ID
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...

# Products → Plan Pro → Price ID
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...

# ── Backend FastAPI (Railway) ─────────────────────────────────────────
# URL del backend en Railway (sin slash final)
NEXT_PUBLIC_API_URL=https://ripsguard-backend.up.railway.app

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://ripsguard.co

# ── Resend (email transaccional) ─────────────────────────────────────
RESEND_API_KEY=re_...

# ═══════════════════════════════════════════════════════════════════
# Variables del BACKEND (Railway) — NO van en Vercel
# ═══════════════════════════════════════════════════════════════════
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_JWT_SECRET=<JWT Secret desde Supabase → Settings → API>
# ANTHROPIC_API_KEY=sk-ant-...
# ALLOWED_ORIGINS=https://ripsguard.co,https://www.ripsguard.co
# ENV=production
